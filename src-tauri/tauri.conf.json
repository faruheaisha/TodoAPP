{
  "$schema": "https://raw.githubusercontent.com/nicholasgriffith/tauri-v2-schema/master/config.schema.json",
  "productName": "TodoApp",
  "version": "0.1.0",
  "identifier": "com.todoapp.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TodoApp",
        "width": 780,
        "height": 600,
        "minWidth": 860,
        "minHeight": 700,
        "resizable": true,
        "center": true,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "scope": [
          "$APPDATA/**",
          "$RESOURCE/**"
        ]
      }
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": false,
      "title": "TodoApp",
      "tooltip": "TodoApp"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": [
          "SimpChinese",
          "English"
        ]
      },
      "webviewInstallMode": {
        "type": "skip"
      }
    }
  }
}